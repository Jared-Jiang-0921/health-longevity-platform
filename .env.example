# Stripe 公钥（Publishable key），用于前端
# 从 https://dashboard.stripe.com/apikeys 获取，测试用 pk_test_ 开头
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Stripe 密钥（Secret key），仅服务端 —— Vercel / vercel dev 环境变量，勿写入 VITE_*
# STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# Stripe Webhook 签名密钥（仅 api/stripe-webhook.js），Dashboard → Webhooks → 端点详情
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Neon / Postgres（仅服务端）
# DATABASE_URL=postgresql://...

# JWT 签名密钥（仅服务端 lib/auth.js）；在 VERCEL 或 NODE_ENV=production 下必填
# JWT_SECRET=至少 32 字符随机字符串

# 支付提供方（stripe | airwallex），默认 stripe
# VITE_PAYMENT_PROVIDER=stripe

# 支付币种（按配置切换）：前端展示 + 后端 Stripe 下单
# 建议同时配置两项为同一值，例如 USD / EUR / GBP / HKD / SGD / AUD / JPY / CNY
# VITE_PAYMENT_CURRENCY=USD
# PAYMENT_CURRENCY=usd
# 手动汇率配置（不依赖第三方 API）：格式 货币:汇率，逗号分隔。建议与基准币种一起配置。
# 含义：1 个基准币种 = 若干目标币种（示例基准 USD）
# VITE_PAYMENT_BASE_CURRENCY=USD
# PAYMENT_BASE_CURRENCY=usd
# VITE_PAYMENT_MANUAL_RATES=USD:1,EUR:0.92,CNY:7.20,HKD:7.80,SGD:1.35
# PAYMENT_MANUAL_RATES=usd:1,eur:0.92,cny:7.20,hkd:7.80,sgd:1.35
# 可选：前端下拉可选币种（逗号分隔，需与后端允许列表一致）
# VITE_PAYMENT_CURRENCY_OPTIONS=USD,EUR,GBP
# PAYMENT_CURRENCY_OPTIONS=usd,eur,gbp

# 支付日志查询管理员配置（api/payment-event-logs.js）
# 二选一：
# 1) 管理员 token（请求头 x-admin-token）
# PAYMENT_LOGS_ADMIN_TOKEN=replace_with_strong_random_token
# 2) 管理员邮箱白名单（请求需带登录 JWT）
# PAYMENT_LOGS_ADMIN_EMAILS=admin@example.com,ops@example.com
# 统计接口：GET /api/payment-event-logs?mode=summary&hours=24&provider=stripe

# 整站用户管理（api/admin-users.js，与支付巡检独立）
# SITE_ADMIN_TOKEN=replace_with_strong_random_token
# 请求头：x-site-admin-token
# SITE_ADMIN_EMAILS=admin@example.com
# 页面：/ops/users；GET /api/admin-users?q=&limit=&offset=；PATCH JSON { user_id, name?, level?, expires_at? }

# 忘记密码邮件（api/auth/forgot-password.js）— 未配置时仍可提交邮箱，但无法发信（服务端日志会打印重置链接便于调试）
# APP_PUBLIC_URL=https://your-domain.com
# EMAIL_BRAND_NAME=Health Longevity Platform
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="noreply@your-domain.com"

# TOTP 双因素（验证器 App）：登录第二步 + 会员信息页启用
# TOTP_ISSUER=Longvity

# 可选：覆盖前端 checkout API 地址。默认会随 VITE_PAYMENT_PROVIDER 自动切换：
# stripe -> /api/create-checkout-session
# airwallex -> /api/airwallex/create-checkout-session
# VITE_CHECKOUT_API=

# Airwallex（空中云汇）骨架变量（当前尚未接入真实 SDK）
# AIRWALLEX_WEBHOOK_SECRET=
# AIRWALLEX_MOCK_REDIRECT_URL=https://example.com/mock-airwallex-checkout

# 可选：创建 PaymentIntent 的后端 API 地址（默认请求同源 /api/create-payment-intent）
# 若后端单独部署，例如：VITE_PAYMENT_INTENT_API=https://your-api.com/create-payment-intent
# VITE_PAYMENT_INTENT_API=

# —— Longevity 咨询双端口（longevityconsult / Manus）——
# 填完整 URL（含 https、端口、路径）。构建时注入，改后需重新 npm run build 再部署 dist。
#
# 专业健康长寿咨询：
# VITE_CONSULT_PROFESSIONAL_URL=https://longevityconsult.vip:8443/你的专业入口路径
# 兼容旧变量名（二选一即可）：
# VITE_MANUS_PROFESSIONAL_URL=
#
# 自我健康促进咨询（可与专业同址，由链接参数 hl_consult_entry=general 区分）：
# VITE_CONSULT_GENERAL_URL=https://longevityconsult.vip:8443/你的大众入口路径
# VITE_MANUS_SELF_URL=
#
# 若只配专业 URL、不配大众 URL，则大众入口自动与专业同址，仍带 hl_consult_entry=general。

# 可选：内容资源 / 知识库 H5（与咨询并列；须 https，链接会带 hl_channel=content）
# VITE_CONTENT_ENTRY_URL=https://longevityconsult.vip:8443/你的内容页路径
# VITE_LONGEVITY_CONTENT_URL=
# VITE_MANUS_CONTENT_URL=

# Coze 智能体 API 代理（可选；在页面底部「平台内置智能体」展开使用）
# 示例：VITE_COZE_PROXY=http://localhost:4243
VITE_COZE_PROXY=http://localhost:4243

# 转人工入口（邮箱、客服链接等）
# VITE_HUMAN_CONTACT_URL=mailto:support@your-domain.com

# ---------- 安全与运维（ECS）----------
# 勿将 .env / .env.prod / 备份包提交 Git；生产密钥勿粘贴到公开聊天。
# ECS 上建议：chmod 600 /opt/health-longevity-platform/.env.prod
# 轮换密钥后：更新 .env.prod → systemctl restart healthlongevity-api
# 脚本：scripts/ops/secure-env-on-server.sh、backup-config.sh、health-check.sh、ops-self-check.sh
# Nginx 安全响应头：deploy/nginx-healthlongevity.conf.example
# 数据库：Neon 控制台确认备份 / PITR 保留策略
