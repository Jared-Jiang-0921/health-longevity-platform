# Stripe 公钥（Publishable key），用于前端
# 从 https://dashboard.stripe.com/apikeys 获取，测试用 pk_test_ 开头
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# 可选：创建 PaymentIntent 的后端 API 地址（默认请求同源 /api/create-payment-intent）
# 若后端单独部署，例如：VITE_PAYMENT_INTENT_API=https://your-api.com/create-payment-intent
# VITE_PAYMENT_INTENT_API=

# Coze 智能体 API 代理地址（用于「健康长寿方案」对话）
# 示例：VITE_COZE_PROXY=http://localhost:4243
VITE_COZE_PROXY=http://localhost:4243

# 转人工入口（邮箱、客服链接等）
# VITE_HUMAN_CONTACT_URL=mailto:support@your-domain.com
