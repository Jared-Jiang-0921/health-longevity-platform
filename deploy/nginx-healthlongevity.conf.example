# 长寿健康平台 — Nginx 站点示例
# 用法：复制到 ECS 后按需改名，例如：
#   sudo cp nginx-healthlongevity.conf.example /etc/nginx/conf.d/healthlongevity.conf
# 若 Ubuntu 使用 sites-available：
#   sudo cp ... /etc/nginx/sites-available/healthlongevity
#   sudo ln -sf /etc/nginx/sites-available/healthlongevity /etc/nginx/sites-enabled/
#
# 修改后执行：sudo nginx -t && sudo systemctl reload nginx
#
# 若出现「Welcome to nginx!」，通常是未加载本配置，或 default 站点抢占了未匹配的域名。
#
# 安全：下方含基础响应头；HTTPS 块请额外加 HSTS。修改后 nginx -t && systemctl reload nginx

# ---------- HTTP（可先恢复访问；有证书后再用 certbot 或下方 HTTPS 块）----------
server {
    listen 80;
    listen [::]:80;
    server_name healthlongevity.cn www.healthlongevity.cn;

    server_tokens off;

    root /opt/health-longevity-platform/dist;
    index index.html;

    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

